# Database
# SQLite (default for local development — zero setup)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production or local Postgres)
# DATABASE_URL="postgresql://user:password@localhost:5432/halalflow?schema=public"

# Session — must be at least 32 characters. Change for production.
SESSION_SECRET="change-me-to-a-random-32-char-string-halalflow"

# Optional workflow notifications (email). Leave unset to skip sending.
RESEND_API_KEY=""
HALALFLOW_EMAIL_FROM="HalalFlow <notifications@halalflow.app>"

# Public base URL for email links and invitations
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
