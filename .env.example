# Database — PostgreSQL. Three URLs:
#   DATABASE_URL       : runtime app role (least privilege, RLS-enforced). Prisma Client.
#   DATABASE_URL_ADMIN : BYPASSRLS admin role. Provisioning, webhooks, cross-org lookups.
#   DIRECT_URL         : owner/superuser. Used by `prisma migrate` (DDL) only.
DATABASE_URL="postgresql://mosrev_app:password@localhost:5432/mosrev?schema=public"
DATABASE_URL_ADMIN="postgresql://mosrev_admin:password@localhost:5432/mosrev?schema=public"
DIRECT_URL="postgresql://owner:password@localhost:5432/mosrev?schema=public"

# Session — must be at least 32 characters. Change for production.
SESSION_SECRET="change-me-to-a-random-32-char-string-halalflow"

# Optional workflow notifications (email). Leave unset to skip sending.
RESEND_API_KEY=""
HALALFLOW_EMAIL_FROM="HalalFlow <notifications@halalflow.app>"

# Public base URL for email links and invitations
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Billing (Stripe) — OPTIONAL. Leave all unset to disable billing entirely:
# the paywall no-ops and every workspace runs in trial mode with full access.
#   STRIPE_SECRET_KEY     : enables Stripe (sk_test_… / sk_live_…).
#   STRIPE_WEBHOOK_SECRET : verifies /api/webhooks/stripe (whsec_…).
#   STRIPE_PRICE_ID       : recurring price for checkout (price_…).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
